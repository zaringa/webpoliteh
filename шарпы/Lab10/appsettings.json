{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Lab10.Services": "Debug",
      "Lab10.Endpoints": "Information"
    },
    "File": {
      "Path": "Logs/lab10-file.log",
      "MinLevel": "Information",
      "IncludeScopes": true
    },
    "Database": {
      "ConnectionString": "Data Source=Logs/lab10-logs.db",
      "TableName": "ApplicationLogs",
      "MinLevel": "Warning"
    }
  },
  "AllowedHosts": "*"
}
